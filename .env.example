# Zammad MCP Server Configuration

# Zammad instance URL (required)
# Used for API calls and to derive OAuth endpoints when not explicitly set.
ZAMMAD_URL=https://your-instance.zammad.com/api/v1

# === Zammad Authentication ===
# Choose ONE of the following methods:

# Option 1: OAuth via Zammad's Doorkeeper (recommended for multi-user)
# Users authenticate through Zammad's login page (which may offer Google,
# GitHub, etc. depending on the Zammad instance's config). The resulting
# Zammad bearer token is forwarded to the API per-request.
# See "Auth Provider Configuration" section below.

# Option 2: API Token (recommended for single-user / service accounts)
ZAMMAD_HTTP_TOKEN=your-api-token-here

# Option 3: OAuth2 Token (static)
# ZAMMAD_OAUTH2_TOKEN=your-oauth2-token-here

# Option 4: Username and Password
# ZAMMAD_USERNAME=your-username
# ZAMMAD_PASSWORD=your-password

# Optional: Disable TLS certificate verification (NOT recommended for production)
# Use only for self-signed/internal cert chains when you trust the network path.
# Truthy values only: 1, true, yes, on. Unset (default) keeps TLS verification enabled.
# ZAMMAD_INSECURE=true

# Optional: Logging level (default: INFO)
# Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO

# === Transport Configuration ===

# Transport type: stdio (default) or http
# MCP_TRANSPORT=stdio

# HTTP Transport Settings (required if MCP_TRANSPORT=http)
# Host to bind to (default: 127.0.0.1)
# MCP_HOST=127.0.0.1

# Port to listen on (default: 8000)
# MCP_PORT=8000

# === SSL Configuration (optional) ===
# Enable HTTPS for the MCP server. Required for local OAuth development
# because Zammad's Doorkeeper enforces HTTPS redirect URIs in production mode.
# Generate a self-signed cert for local dev:
#   openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem -days 365 -nodes -subj "/CN=localhost"
# MCP_SSL_CERTFILE=cert.pem
# MCP_SSL_KEYFILE=key.pem

# === Auth Provider Configuration (OAuth via Zammad's Doorkeeper) ===
# Enable OAuth so MCP clients authenticate through Zammad on the fly.
# Prerequisites:
#   1. Create an OAuth application in Zammad via the admin API:
#      curl -X POST -H "Authorization: Token token=YOUR_ADMIN_TOKEN" \
#        -H "Content-Type: application/json" \
#        -d '{"name": "MCP Server", "redirect_uri": "https://localhost:8000/auth/callback", "scopes": "full"}' \
#        https://your-instance.zammad.com/api/v1/applications
#      The "scopes": "full" field is required — without it, clients get an
#      "invalid_scope" error during the OAuth flow.
#   2. Retrieve the client ID (uid) and secret:
#      curl -H "Authorization: Token token=YOUR_ADMIN_TOKEN" \
#        "https://your-instance.zammad.com/api/v1/applications?full=true"
#   3. The redirect URI must match MCP_AUTH_BASE_URL + /auth/callback
#   4. Use HTTP transport (MCP_TRANSPORT=http) — OAuth requires HTTP, not stdio

# Zammad OAuth application client ID (the "uid" field from the API response)
# MCP_AUTH_CLIENT_ID=your-zammad-oauth-app-client-id

# Zammad OAuth application client secret
# MCP_AUTH_CLIENT_SECRET=your-zammad-oauth-app-client-secret

# Public URL of this MCP server (used for OAuth callbacks)
# Must use HTTPS if Zammad enforces HTTPS redirect URIs (production mode)
# MCP_AUTH_BASE_URL=https://localhost:8000
